{
  "name": "@shipitandpray/pretext-logviewer",
  "version": "0.1.0",
  "description": "High-performance log viewer for 10M+ lines with ANSI color parsing, virtualized scroll, and instant search.",
  "author": "ShipItAndPray",
  "license": "MIT",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "demo:dev": "npx -y vite demo",
    "demo:build": "npx -y vite build demo",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "@pretext/core": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@pretext/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@testing-library/react": "^15.0.0",
    "jsdom": "^24.0.0"
  },
  "keywords": [
    "log-viewer",
    "ansi",
    "virtualized",
    "scroll",
    "react",
    "devops",
    "pretext",
    "word-wrap",
    "search",
    "streaming"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ShipItAndPray/pretext-logviewer"
  },
  "homepage": "https://shipitandpray.github.io/pretext-logviewer/"
}
